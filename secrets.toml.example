# קובץ זה הוא תבנית בלבד — לא להעלות לגיטהאב!
# צור קובץ .streamlit/secrets.toml על המחשב שלך עם הערכים האמיתיים

APP_PASSWORD = "הסיסמה_שלך_כאן"

# אופציונלי — להסברים AI על חלופות
ANTHROPIC_API_KEY = "sk-ant-..."

# אופציונלי — לסטטיסטיקות הצבעה
# [gcp_service_account]
# type = "service_account"
# project_id = "your-project"
# private_key_id = "..."
